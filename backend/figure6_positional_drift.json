    "drift": 0.0,
    "alignment_status": "high"
  },
  {
    "sentence_id": 154,
    "novel": "Noli Me Tangere",
    "chapter": 7,
    "buod_text": "Sa simbahan palang ay di na mapakali si Maria Clara dahil alam niyang darating si Ibarra sa araw na iyon.",
    "estimated_position_normalized": 0.0,
    "actual_position_normalized": 0.221,
    "drift": 0.221,
    "alignment_status": "high"
  },
  {
    "sentence_id": 171,
    "novel": "Noli Me Tangere",
    "chapter": 8,
    "buod_text": "Ang kalungkutang naramdaman ni Ibarra sa pag-alis niya sa bahay ni Maria Clara ay napalitan ng kagalakan nang libutin niya ang kamaynilaan sakay sa kalesa.",
    "estimated_position_normalized": 0.0,
    "actual_position_normalized": 0.0,
    "drift": 0.0,
    "alignment_status": "medium"
  },
  {
    "sentence_id": 187,
    "novel": "Noli Me Tangere",
    "chapter": 9,
    "buod_text": "Papunta si Padre Damaso sa bahay nila Kapitan Tiago nang makasalubong nito si Ibarra.",
    "estimated_position_normalized": 0.0,
    "actual_position_normalized": 0.0,
    "drift": 0.0,
    "alignment_status": "medium"
  },
  {
    "sentence_id": 203,
    "novel": "Noli Me Tangere",
    "chapter": 10,
    "buod_text": "Ang bayan ng San Diego ay matatagpuan sa gitna ng palayan na siyang malapit din sa lawa.",
    "estimated_position_normalized": 0.0,
    "actual_position_normalized": 0.0,
    "drift": 0.0,
    "alignment_status": "high"
  },
  {
    "sentence_id": 228,
    "novel": "Noli Me Tangere",
    "chapter": 11,
    "buod_text": "Si Don Rafael ay hindi makapangyarihan bagamat siya ang pinakamayaman sa lugar.",
    "estimated_position_normalized": 0.0,
    "actual_position_normalized": 0.043,
    "drift": 0.043,
    "alignment_status": "high"
  },
  {
    "sentence_id": 238,
    "novel": "Noli Me Tangere",
    "chapter": 12,
    "buod_text": "Ang sementeryo ng San Diego ay matatagpuan sa gitna ng malawak na palayan.",
    "estimated_position_normalized": 0.0,
    "actual_position_normalized": 0.1,
    "drift": 0.1,
    "alignment_status": "medium"
  },
  {
    "sentence_id": 248,
    "novel": "Noli Me Tangere",
    "chapter": 13,
    "buod_text": "Sakay sa kanyang kalesa, nagtungo si Ibarra sa sementeryo kasama ang kanyang katiwala upang hanapin ang nitso ng amang si Don Rafael.",
    "estimated_position_normalized": 0.0,
    "actual_position_normalized": 0.01,
    "drift": 0.01,
    "alignment_status": "medium"
  },
  {
    "sentence_id": 267,
    "novel": "Noli Me Tangere",
    "chapter": 14,
    "buod_text": "Si Don Anastacio o mas kilala sa tawag na Pilosopo Tasyo ay kilala sa San Diego dahil siya ay may kakaibang pananaw tungkol sa pulitika at mga paniniwala.",
    "estimated_position_normalized": 0.0,
    "actual_position_normalized": 0.035,
    "drift": 0.035,
    "alignment_status": "medium"
  },
  {
    "sentence_id": 288,
    "novel": "Noli Me Tangere",
    "chapter": 15,
    "buod_text": "Ang dalawang magkapatid na nakita ni Pilosopo Tasyo ay nasa ikalawang palapag ng simbahan.",
    "estimated_position_normalized": 0.0,
    "actual_position_normalized": 0.027,
    "drift": 0.027,
    "alignment_status": "medium"
  },
  {
    "sentence_id": 370,
    "novel": "Noli Me Tangere",
    "chapter": 20,
    "buod_text": "Ang bulwagang pulungan ng San Diego ay dinadaluhan ng mga kinikilalang mamamayan na pawang nagbibigay ng opinyon para sa ikakaganda ng bayan.",
    "estimated_position_normalized": 0.0,
    "actual_position_normalized": 0.015,
    "drift": 0.015,
    "alignment_status": "medium"
  },
  {
    "sentence_id": 447,
    "novel": "Noli Me Tangere",
    "chapter": 25,
