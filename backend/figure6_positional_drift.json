    "drift": 0.0,
    "alignment_status": "high"
  },
  {
    "sentence_id": 99,
    "novel": "Noli Me Tangere",
    "chapter": 5,
    "buod_text": "Dumating si Ibarra sa kanyang tinutuluyan sa Fonda de Lala.",
    "estimated_position_normalized": 0.0,
